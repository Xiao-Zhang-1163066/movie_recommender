// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String   @id @default(uuid())
  name     String
  email    String   @unique
  password String
  createdAt DateTime @default(now())

  movies   Movie[]  @relation("MovieCreator") // Relation to movies created by the user
  watchlistItems WatchlistItem[]
}

model Movie {
  id          String   @id @default(uuid())
  tmdbId      Int?     @unique
  title       String
  overview    String?
  releaseYear Int
  genres      String[] @default([])
  runtime     Int?
  posterUrl   String?
  createdBy   String
  createdAt   DateTime @default(now())
  creator    User     @relation("MovieCreator",fields: [createdBy], references: [id], onDelete: Cascade) // Ensure that if a user is deleted, the corresponding movies are also deleted
  watchlistItems WatchlistItem[]
  sessions    Session[]
}

model WatchlistItem {
  id        String   @id @default(uuid())
  userId    String
  movieId   String
  status    WatchlistStatus @default(PLANNED)   
  rating    Int? // User rating for the movie (1-10)
  notes     String? // User notes about the movie
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  //relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)// Ensure that if a user or movie is deleted, the corresponding watchlist items are also deleted

  @@unique([userId, movieId]) // Ensure a user can only have one entry per movie in their watchlist
}

enum WatchlistStatus {
  PLANNED
  WATCHING
  COMPLETED
  DROPPED
}

model Cinema {                                                                                
  id         String    @id @default(uuid())
  // cinema display name
  name       String
  // URL-safe identifier, must be unique                                                        
  slug       String     @unique
  // street address                                                                             
  address    String                                                                              
  // Christchurch suburb                                                                        
  suburb     String                                                                              
  // map coordinates
  latitude   Float  
  longitude  Float
  // where users go to browse / buy tickets                                                     
  websiteUrl String
  bookingUrl String?       // optional — not all cinemas have a direct booking page                 
  // where the scraper pulls showtime data from                                                 
  scrapeUrl  String                                                                                
  // default to NZ timezone                                                                     
  timezone   String    @default("Pacific/Auckland")                                           
  // soft-disable a cinema without deleting it                                                  
  isActive   Boolean   @default(true)                                                           
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt                                                               
  // relation field — list of all sessions at this cinema                                     
  sessions   Session[]                                                                                 
  }    

  model Session {
  id              String   @id @default(uuid())
  // foreign keys
  cinemaId        String
  movieId         String
  // when the film starts
  startsAt        DateTime
  // e.g. "Standard", "IMAX", "3D"
  format          String   @default("Standard")
  // optional — scraper may not have this
  seatsTotal      Int?
  seatsRemaining  Int?
  // direct link to this specific session's booking page
  bookingUrl      String?      // optional
  // the cinema's own internal ID for this session (for deep-linking)
  sourceSessionId String?      // optional
  scrapedAt       DateTime @default(now())
  createdAt       DateTime @default(now())
  // relation back to Cinema
  cinema          Cinema     @relation(fields: [cinemaId], references: [id], onDelete: Cascade)
  // relation back to Movie
  movie           Movie      @relation(fields: [movieId], references: [id], onDelete: Cascade)
  // indexes for fast lookups 
  @@index([movieId, startsAt])
  @@index([cinemaId, startsAt])
}